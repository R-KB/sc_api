<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.app.mapper.MemoMapper">
	
	<resultMap id="joinMap" type="Memo" autoMapping="true">
		<id property="id" column="id" />
	</resultMap>
	
	<select id="selectMemo" resultMap="joinMap">
		SELECT id, q_id, memo, created, updated FROM memo
	</select>
	
	<select id="selectMemoById" resultMap="joinMap">
		SELECT id, q_id, memo, created, updated FROM memo
		WHERE id = #{id}
	</select>
	
	<select id="selectMemoByQuestion" resultMap="joinMap">
		SELECT id, q_id, memo, created, updated FROM memo
		WHERE q_id = #{qId}
	</select>
	
	<insert id="insert" parameterType="Memo">
		INSERT INTO memo(q_id, memo) VALUES (#{qId}, #{memo})
	</insert>
	
	<update id="update" parameterType="Memo">
		UPDATE memo set q_id = #{qId}, memo = #{memo} WHERE id = #{id}
	</update>
	
	<delete id="delete" parameterType="Memo">
		DELETE FROM memo WHERE id = #{id}
	</delete>
	
	


</mapper>